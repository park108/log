{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["DOM", "DOM.Iterable", "ES2020"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noImplicitAny": true,
		"noUncheckedIndexedAccess": true,
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@/common/*": ["src/common/*"],
			"@/types/*": ["src/types/*"],
			"@/log/*": ["src/Log/*"]
		},
		"noEmit": true
	},
	"include": ["src"]
}
