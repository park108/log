# Copy to .env.development.local and .env.production.local and fill in real values.
# These files are gitignored. For Amplify, set these via App settings > Environment variables.

# API Gateway base domains (no trailing /prod or /test — appended at runtime)
VITE_LOG_API_BASE=
VITE_SEARCH_API_BASE=
VITE_MONITOR_API_BASE=
VITE_IMAGE_API_BASE=
VITE_FILE_API_BASE=
VITE_COMMENT_API_BASE=

# Cognito Hosted UI URLs (full URL with client_id, scopes, redirect_uri)
VITE_COGNITO_LOGIN_URL_PROD=
VITE_COGNITO_LOGIN_URL_DEV=
VITE_COGNITO_LOGOUT_URL_PROD=
VITE_COGNITO_LOGOUT_URL_DEV=
