{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": ["*"],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(git commit --amend*)",
      "Bash(git config*)",
      "Bash(*--no-verify*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)"
    ]
  }
}
